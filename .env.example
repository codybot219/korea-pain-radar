# Discord Incoming Webhook URL (recommended)
DISCORD_WEBHOOK_URL=

# Collection options
PAIN_RADAR_TIMEOUT_MS=12000
PAIN_RADAR_MAX_ITEMS_PER_SOURCE=80
PAIN_RADAR_WINDOW_HOURS=72
PAIN_RADAR_USER_AGENT=PainRadarKR/0.1 (+https://github.com)

# Source auto-discovery / auto-update
PAIN_RADAR_AUTO_SOURCE_UPDATE=1
PAIN_RADAR_SOURCE_UPDATE_INTERVAL_HOURS=24
PAIN_RADAR_SOURCE_DISCOVERY_TIMEOUT_MS=12000
PAIN_RADAR_SOURCE_DISCOVERY_MIN_ITEMS=12
PAIN_RADAR_SOURCE_DISCOVERY_MAX_NEW=400
PAIN_RADAR_SOURCE_DISCOVERY_MAX_PROBES=1500
