{
  "name": "korea-pain-radar",
  "version": "0.1.0",
  "private": true,
  "description": "Korean community pain-point crawler and market-idea radar",
  "type": "commonjs",
  "scripts": {
    "collect": "node src/collect.js",
    "analyze": "node src/analyze.js",
    "report": "node src/report-discord.js",
    "sources:discover": "node src/discover-sources.js",
    "sources:discover:write": "node src/discover-sources.js --write",
    "sources:auto-update": "node src/source-auto-update.js",
    "sources:auto-update:force": "node src/source-auto-update.js --force",
